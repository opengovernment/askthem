# Prisma SQLite database (relative to project root via prisma.config.ts)
DATABASE_URL="file:./prisma/dev.db"

# ─── Action Network CRM ─────────────────────────────────────────────
# API key from your AN group's API & Sync settings (partner tier required).
# When unset, AN sync is silently skipped — safe for local dev.
# ACTION_NETWORK_API_KEY=

# Optional: map all question signatures to a single AN petition resource.
# If unset, signatures are recorded via person tagging instead.
# ASKTHEM_AN_PETITION_ID=

# ─── Mailgun Transactional Email ─────────────────────────────────────
# Required for email sign-in (magic links) and transactional notifications.
# When unset, transactional emails are silently skipped — safe for local dev,
# but email sign-in will fail.
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mg.askthem.io
# MAILGUN_FROM=AskThem <noreply@mg.askthem.io>

# ─── Authentication (Auth.js / NextAuth) ─────────────────────────────
# Required: secret for signing session cookies (generate with: openssl rand -base64 32)
AUTH_SECRET="change-me-in-production"

# Base URL for OAuth callbacks — MUST match your deployment domain.
# Auth.js uses this to build callback URLs (e.g. {AUTH_URL}/api/auth/callback/google).
# For Vercel: set in Vercel Dashboard → Settings → Environment Variables.
# AUTH_URL=https://askthem.vercel.app

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
# Optional: when unset, Google sign-in button is hidden.
# IMPORTANT: Add this Authorized Redirect URI in Google Cloud Console:
#   {AUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Facebook OAuth credentials (https://developers.facebook.com/apps/)
# Optional: when unset, Facebook sign-in button is hidden.
# IMPORTANT: Add this Valid OAuth Redirect URI in Facebook App Settings:
#   {AUTH_URL}/api/auth/callback/facebook
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# ─── Cicero API (Elected Official Lookup) ──────────────────────────
# API key from https://cicerodata.com — used to look up elected officials by address.
# Sign up for a free trial (1,000 credits / 90 days) at https://cicerodata.com/free-trial/
# When unset, address lookup is unavailable (returns 503) — safe for local dev.
# CICERO_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────
# Base URL for links in transactional emails.
# NEXT_PUBLIC_BASE_URL=https://askthem.io
