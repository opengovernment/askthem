// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Users & Authentication ──────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime? // Auth.js: set when email is verified via OAuth
  name              String
  image             String?   // Auth.js: profile photo from OAuth provider
  streetAddress     String?
  city              String?
  state             String?
  zip               String?
  isAddressVerified Boolean   @default(false)
  role              String    @default("user") // "user" | "moderator" | "admin"
  actionNetworkId   String?   // Action Network person UUID (synced on registration)
  emailConsent      Boolean   @default(false) // user opted in to email communications
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  questions   Question[]
  upvotes     Upvote[]
  accounts    Account[]
  sessions    Session[]
  emailEvents EmailEvent[]
}

// Auth.js Account model (replaces OAuthAccount)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  // "oauth" | "oidc"
  provider          String  // "google", "github", etc.
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Auth.js Session model (database sessions)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Elected Officials ───────────────────────────────────────────────

model Official {
  id       String  @id @default(cuid())
  name     String
  title    String
  party    String
  state    String
  district String?
  chamber  String  // "senate" | "house" | "state_senate" | "state_house" | "local"
  photoUrl String?
  email    String?
  twitter  String?
  phone    String?
  website  String?

  questions       Question[]
  userDistricts   UserDistrict[]
}

// Maps users to their elected officials based on address lookup
model UserDistrict {
  id         String @id @default(cuid())
  userId     String
  officialId String
  official   Official @relation(fields: [officialId], references: [id])

  @@unique([userId, officialId])
}

// ─── Questions ───────────────────────────────────────────────────────

model Question {
  id          String   @id @default(cuid())
  text        String
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  officialId  String
  official    Official @relation(fields: [officialId], references: [id])
  districtTag String
  status      String   @default("pending_review") // "pending_review" | "published" | "delivered" | "answered"
  upvoteCount Int      @default(0) // denormalized for fast sorting
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Delivery tracking
  deliveredAt      DateTime?
  deliveredVia     String?    // "email" | "twitter" | "facebook" | "mail"
  deliveredBy      String?    // moderator ID who delivered

  categoryTags QuestionTag[]
  upvotes      Upvote[]
  answer       Answer?
  emailEvents  EmailEvent[]
}

model QuestionTag {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag        String   // Policy area from Congress.gov

  @@unique([questionId, tag])
}

// ─── Upvotes ─────────────────────────────────────────────────────────

model Upvote {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, questionId])
}

// ─── Answers ─────────────────────────────────────────────────────────

model Answer {
  id               String   @id @default(cuid())
  questionId       String   @unique
  question         Question @relation(fields: [questionId], references: [id])
  responseText     String?
  responseVideoUrl String?
  responseAudioUrl String?
  sourceUrl        String?  // link to social media post, gov website, press release, etc.
  postedBy         String   // moderator ID who posted the answer
  respondedAt      DateTime @default(now())
}

// ─── Email Events (transactional email audit log) ────────────────────

model EmailEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  questionId  String?
  question    Question? @relation(fields: [questionId], references: [id])
  emailType   String   // "question_submitted" | "question_signed" | "question_delivered" | "question_answered"
  subject     String
  sentAt      DateTime @default(now())
  messageId   String?  // Mailgun message ID for tracking
  status      String   @default("sent") // "sent" | "delivered" | "bounced" | "failed"
}

// ─── API Access (for future tiered API) ──────────────────────────────

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  tier      String   @default("free") // "free" | "basic" | "pro" | "enterprise"
  userId    String?
  rateLimit Int      @default(100) // requests per hour
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  lastUsedAt DateTime?
}
